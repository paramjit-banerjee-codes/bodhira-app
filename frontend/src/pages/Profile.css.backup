/* ============================================
   Profile Page - SOLID HIGH CONTRAST DESIGN
   ============================================ */

/* Main Container */
.profile-container {
  min-height: 100vh;
  background: linear-gradient(180deg, 
    #0a0e27 0%, 
    #0f1429 25%, 
    #141a2f 50%, 
    #0f1429 75%, 
    #0a0e27 100%);
  padding: 20px 0 80px;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  position: relative;
  overflow-x: hidden;
  overflow-y: auto;
  width: 100%;
  box-sizing: border-box;
}

/* Background Decorative Shapes - REMOVED for clarity */
.profile-bg-decoration {
  position: fixed;
  pointer-events: none;
  opacity: 0;
  z-index: 0;
  display: none;
}

/* Floating Edit Button */
.profile-floating-edit-btn {
  position: fixed;
  top: 100px;
  right: 30px;
  z-index: 1000;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 24px;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
  border: none;
  border-radius: 50px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  box-shadow: 0 8px 24px rgba(59, 130, 246, 0.4),
              0 0 0 0 rgba(59, 130, 246, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.profile-floating-edit-btn:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(59, 130, 246, 0.5),
              0 0 0 8px rgba(59, 130, 246, 0.15);
}

.edit-btn-icon {
  font-size: 16px;
}

.edit-btn-text {
  display: none;
}

/* Card Wrapper */
.profile-card-wrapper {
  max-width: 850px;
  margin: 0 auto 40px;
  position: relative;
  z-index: 10;
  width: 100%;
  box-sizing: border-box;
  padding: 0 16px;
}

/* Main Solid Card - NO GLASSMORPHISM */
.profile-main-card {
  background: #111c2e;
  border: 1px solid #1f2a3e;
  border-radius: 16px;
  padding: 16px 28px 28px 28px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8),
              0 0 20px rgba(59, 130, 246, 0.2);
  transition: all 0.3s ease;
  box-sizing: border-box;
  width: 100%;
}

.profile-main-card:hover {
  border-color: #3b82f6;
  box-shadow: 0 25px 80px rgba(0, 0, 0, 0.9),
              0 0 30px rgba(59, 130, 246, 0.3);
}

/* Header Section */
.profile-card-header {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 2px solid #1e3a5f;
}

.profile-avatar-section {
  flex-shrink: 0;
}

.profile-avatar-container {
  position: relative;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 44px;
  font-weight: 800;
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5),
              0 0 0 2px #2d5a8f;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.profile-avatar-container:hover {
  transform: scale(1.05);
  box-shadow: 0 16px 50px rgba(59, 130, 246, 0.5),
              0 0 0 3px #3b82f6;
}

.profile-avatar-initials {
  position: relative;
  z-index: 2;
}

.profile-avatar-glow {
  display: none;
}

.profile-header-content {
  flex: 1;
}

.profile-user-name {
  font-size: 28px;
  font-weight: 800;
  color: #ffffff;
  margin: 0 0 2px 0;
  letter-spacing: -0.5px;
}

.profile-user-handle {
  font-size: 13px;
  color: #ffffff;
  margin: 0 0 8px 0;
  font-weight: 500;
}

.profile-role-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  background: #1e3a5f;
  border: 2px solid #3b82f6;
  border-radius: 12px;
  color: #60a5fa;
  font-size: 13px;
  font-weight: 700;
  transition: all 0.2s ease;
}

.profile-role-badge:hover {
  background: #2d5a8f;
  border-color: #60a5fa;
}

.role-icon {
  font-size: 16px;
}

/* Bio Section */
.profile-bio-section {
  margin-bottom: 20px;
  padding: 12px 14px;
  background: #1a2d42;
  border-left: 4px solid #3b82f6;
  border-radius: 8px;
}

.profile-bio {
  color: #ffffff;
  font-size: 14px;
  line-height: 1.6;
  margin: 0;
}

/* Details Grid - SOLID */
.profile-details-grid {
  background: linear-gradient(135deg, #0f1a2f 0%, #111f2e 100%);
  border: 1px solid #1f2a3e;
  border-radius: 20px;
  padding: 20px 18px;
  box-shadow: 0 12px 48px rgba(0, 0, 0, 0.7), inset 0 1px 2px rgba(255, 255, 255, 0.05);
  transition: all 0.3s ease;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}

.profile-detail-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
  text-align: center;
  padding: 16px 12px;
  border-radius: 12px;
  background: linear-gradient(135deg, #0a0f1f 0%, #0d1628 100%);
  border: 1px solid #1f2a3e;
  transition: all 0.3s ease;
  justify-content: center;
  align-items: center;
  min-height: 90px;
}

.profile-detail-item:hover {
  background: linear-gradient(135deg, #1a2d42 0%, #142038 100%);
  border-color: #3b82f6;
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(59, 130, 246, 0.15);
}

.detail-label {
  font-size: 10px !important;
  font-weight: 700 !important;
  color: #cbd5e1 !important;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  opacity: 0.9 !important;
}

.detail-value {
  font-size: 18px !important;
  font-weight: 900 !important;
  color: #ffffff !important;
  word-break: break-all;
  line-height: 1.2;
}

.status-active {
  color: #22c55e !important;
  padding: 6px 14px;
  background: linear-gradient(135deg, #0d4a2a 0%, #0a3d23 100%);
  border: 1px solid #10b981;
  border-radius: 8px;
  display: inline-block;
  width: fit-content;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.3px;
  transition: all 0.3s ease;
}

.status-active:hover {
  border-color: #4ade80;
  box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
}

/* Stats Section - 4 Cards REDESIGNED - Premium & Clean */
.profile-stats-section {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  margin-top: 16px;
}

.profile-quick-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 18px 12px;
  background: rgba(15, 26, 47, 0.4);
  border: 1px solid rgba(59, 130, 246, 0.15);
  border-radius: 14px;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  min-width: 0;
  text-align: center;
  backdrop-filter: blur(10px);
  position: relative;
  overflow: hidden;
}

.profile-quick-stat::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.05) 0%, rgba(168, 85, 247, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.profile-quick-stat:hover {
  transform: translateY(-2px);
  border-color: rgba(59, 130, 246, 0.4);
  background: rgba(15, 26, 47, 0.6);
  box-shadow: 0 8px 24px rgba(59, 130, 246, 0.15);
}

.profile-quick-stat:hover::before {
  opacity: 1;
}

.stat-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
  transition: transform 0.3s ease;
}

.profile-quick-stat:hover .stat-icon {
  transform: scale(1.05);
}

.stat-icon-blue {
  background: rgba(37, 99, 235, 0.15);
  border: 1px solid rgba(59, 130, 246, 0.3);
}

.stat-icon-green {
  background: rgba(5, 150, 105, 0.15);
  border: 1px solid rgba(16, 185, 129, 0.3);
}

.stat-icon-orange {
  background: rgba(217, 119, 6, 0.15);
  border: 1px solid rgba(245, 158, 11, 0.3);
}

.stat-icon-purple {
  background: rgba(124, 58, 237, 0.15);
  border: 1px solid rgba(168, 85, 247, 0.3);
}

.stat-content {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 0;
  flex: 1;
  align-items: center;
  position: relative;
  z-index: 1;
}

.stat-label {
  font-size: 10px !important;
  font-weight: 600 !important;
  color: rgba(255, 255, 255, 0.6) !important;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  white-space: normal;
  line-height: 1.3;
  opacity: 1 !important;
}

.stat-number {
  font-size: 24px !important;
  font-weight: 700 !important;
  color: #ffffff !important;
  line-height: 1.1;
  letter-spacing: -0.5px;
}

/* Content Wrapper */
.profile-content-wrapper {
  max-width: 850px;
  margin: 0 auto;
  position: relative;
  z-index: 10;
  width: 100%;
  box-sizing: border-box;
  padding: 0 16px;
}

/* Loading & Error States */
.profile-loading {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #0a0e27 0%, #0f1429 25%, #141a2f 50%);
}

.profile-loader {
  text-align: center;
  color: #ffffff;
}

.profile-spinner {
  width: 50px;
  height: 50px;
  border: 4px solid rgba(59, 130, 246, 0.3);
  border-top: 4px solid #3b82f6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 16px;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.profile-error {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #0a0e27 0%, #0f1429 25%, #141a2f 50%);
  padding: 20px;
}

.profile-error-box {
  background: rgba(15, 26, 47, 0.8);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 16px;
  padding: 48px 32px;
  text-align: center;
  max-width: 400px;
  backdrop-filter: blur(10px);
}

.profile-error-box .error-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.profile-error-box h2 {
  color: #ffffff;
  font-size: 24px;
  font-weight: 700;
  margin: 0 0 12px 0;
}

.profile-error-box p {
  color: rgba(255, 255, 255, 0.7);
  font-size: 14px;
  margin: 0 0 24px 0;
  line-height: 1.6;
}

.profile-error-box .error-btn {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
  border: none;
  border-radius: 12px;
  padding: 12px 32px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.profile-error-box .error-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(59, 130, 246, 0.3);
}

/* Modal Styles */
.profile-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1001;
}

.profile-modal-content {
  background: #0f1a2f;
  border: 2px solid #2d5a8f;
  border-radius: 20px;
  padding: 32px;
  max-width: 500px;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
}

.profile-modal-header {
  font-size: 24px;
  font-weight: 800;
  color: #ffffff;
  margin: 0 0 24px 0;
}

.profile-modal-close {
  position: absolute;
  top: 20px;
  right: 20px;
  background: #1a2d42;
  border: 2px solid #2d5a8f;
  color: #ffffff;
  font-size: 24px;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  cursor: pointer;
  transition: all 0.2s ease;
}

.profile-modal-close:hover {
  background: #2d5a8f;
  color: #ffffff;
  border-color: #3b82f6;
}

/* Form Styles */
.profile-form-group {
  margin-bottom: 20px;
}

.profile-form-label {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8px;
}

.profile-form-input,
.profile-form-textarea {
  width: 100%;
  padding: 12px 16px;
  background: #1a2d42;
  border: 2px solid #2d5a8f;
  border-radius: 8px;
  color: #ffffff;
  font-family: inherit;
  font-size: 14px;
  transition: all 0.2s ease;
}

.profile-form-input:focus,
.profile-form-textarea:focus {
  outline: none;
  border-color: #3b82f6;
  background: #1e3a5f;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
}

.profile-form-textarea {
  resize: vertical;
  min-height: 100px;
}

.profile-form-hint {
  font-size: 12px;
  color: #ffffff;
  margin-top: 6px;
}

.profile-form-info {
  background: #1a2d42;
  border-left: 3px solid #3b82f6;
  padding: 12px;
  border-radius: 6px;
  font-size: 13px;
  color: #ffffff;
  margin-bottom: 20px;
}

.profile-modal-buttons {
  display: flex;
  gap: 12px;
  margin-top: 28px;
}

.profile-btn-cancel,
.profile-btn-save {
  flex: 1;
  padding: 12px 20px;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
  font-size: 14px;
}

.profile-btn-cancel {
  background: #1a2d42;
  color: #ffffff;
  border: 2px solid #1f2a3e;
}

.profile-btn-cancel:hover {
  background: #2d5a8f;
  border-color: #3b82f6;
}

.profile-btn-save {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
}

.profile-btn-save:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4);
}

/* Footer */
.profile-footer {
  text-align: center;
  margin-top: 40px;
  padding-top: 40px;
  border-top: 2px solid #1e3a5f;
}

.profile-logout-btn {
  padding: 12px 32px;
  background: #5a3a3a;
  border: 2px solid #ef4444;
  color: #ef4444;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}

.profile-logout-btn:hover {
  background: #6b4a4a;
  box-shadow: 0 8px 20px rgba(239, 68, 68, 0.3);
}

.profile-footer-text {
  font-size: 12px;
  color: #ffffff;
  margin-top: 12px;
}

/* Responsive - Tablet */
@media (max-width: 768px) {
  .profile-floating-edit-btn {
    top: 80px;
    right: 16px;
    padding: 10px 16px;
    font-size: 12px;
  }

  .profile-card-wrapper {
    padding: 0 12px;
  }

  .profile-main-card {
    padding: 20px;
  }

  .profile-avatar-container {
    width: 80px;
    height: 80px;
    font-size: 36px;
  }

  .profile-user-name {
    font-size: 22px;
  }

  .profile-stats-section {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  .profile-quick-stat {
    padding: 16px 12px;
  }

  .stat-icon {
    width: 32px;
    height: 32px;
    font-size: 16px;
  }

  .stat-number {
    font-size: 20px !important;
  }

  .stat-label {
    font-size: 9px !important;
  }
}

/* Responsive - Mobile */
@media (max-width: 480px) {
  .profile-container {
    padding: 20px 12px 60px;
  }

  .profile-floating-edit-btn {
    top: 70px;
    right: 12px;
    padding: 8px 12px;
    font-size: 12px;
  }

  .profile-main-card {
    padding: 16px;
  }

  .profile-avatar-container {
    width: 70px;
    height: 70px;
    font-size: 32px;
  }

  .profile-user-name {
    font-size: 18px;
  }

  .profile-stats-section {
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }

  .profile-quick-stat {
    padding: 14px 10px;
  }

  .stat-icon {
    width: 30px;
    height: 30px;
    font-size: 15px;
  }

  .stat-number {
    font-size: 18px !important;
  }

  .stat-label {
    font-size: 8px !important;
  }
    height: 36px;
    font-size: 18px;
  }

  .stat-number {
    font-size: 20px;
  }

  .stat-label {
    font-size: 10px;
  }
}

/* ==================== SECTION STYLES ==================== */

.profile-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  margin-bottom: 40px;
}

.profile-stat-card {
  background: rgba(15, 26, 47, 0.6);
  border: 1px solid rgba(59, 130, 246, 0.1);
  border-radius: 16px;
  padding: 20px 18px;
  display: flex;
  align-items: center;
  gap: 14px;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(10px);
  position: relative;
  overflow: hidden;
}

.profile-stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.03) 0%, rgba(168, 85, 247, 0.03) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.profile-stat-card:hover {
  transform: translateY(-2px);
  border-color: rgba(59, 130, 246, 0.3);
  background: rgba(15, 26, 47, 0.8);
  box-shadow: 0 8px 24px rgba(59, 130, 246, 0.15);
}

.profile-stat-card:hover::before {
  opacity: 1;
}

.profile-stat-icon-wrapper {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.profile-stat-card:hover .profile-stat-icon-wrapper {
  transform: scale(1.05);
}

.profile-stat-emoji {
  font-size: 20px;
  line-height: 1;
}

.profile-stat-content {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
  flex: 1;
}

.profile-stat-label {
  font-size: 11px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.6);
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin: 0;
  line-height: 1.2;
}

.profile-stat-value {
  font-size: 26px;
  font-weight: 700;
  margin: 0;
  color: #ffffff;
  line-height: 1.1;
  letter-spacing: -0.5px;
}

/* Sections */
.profile-section {
  background: #0f1a2f;
  border: 1px solid #1f2a3e;
  border-radius: 16px;
  padding: 32px;
  margin-bottom: 32px;
  transition: all 0.3s ease;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
}

.profile-section:hover {
  border-color: #3b82f6;
  box-shadow: 0 12px 32px rgba(59, 130, 246, 0.2);
}

.profile-section-title {
  font-size: 20px;
  font-weight: 800;
  color: #ffffff;
  margin: 0 0 24px 0;
}

/* Learning Grid */
.profile-learning-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}

.profile-learning-card {
  background: #0f1a2f;
  border: 1px solid #1f2a3e;
  border-radius: 12px;
  padding: 20px;
  transition: all 0.3s ease;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
}

.profile-learning-card:hover {
  border-color: #3b82f6;
  background: #1a2d42;
  box-shadow: 0 12px 32px rgba(59, 130, 246, 0.2);
}

.profile-learning-card-title {
  font-size: 16px;
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 16px 0;
}

.profile-topics-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.profile-topic-badge {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: #0f1a2f;
  border-radius: 8px;
  border: 1px solid #1f2a3e;
  transition: all 0.2s ease;
}

.profile-topic-badge:hover {
  transform: translateX(4px);
  border-color: #3b82f6;
  background: #1a2d42;
}

.profile-topic-name {
  font-weight: 600;
  color: #ffffff;
  display: block;
  margin-bottom: 2px;
}

.profile-topic-score {
  font-size: 12px;
  color: #ffffff;
  display: block;
}

.profile-empty-state {
  color: #ffffff;
  font-size: 14px;
  padding: 16px;
  text-align: center;
  background: #0f1a2f;
  border: 1px solid #1f2a3e;
  border-radius: 8px;
}

/* Performance Card */
.profile-performance-card {
  background: #0f1a2f;
  border: 1px solid #1f2a3e;
  border-radius: 16px;
  padding: 32px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
  transition: all 0.3s ease;
}

.profile-performance-card:hover {
  border-color: #3b82f6;
  box-shadow: 0 15px 50px rgba(59, 130, 246, 0.25);
}

.profile-performance-card:hover {
  border-color: #3b82f6;
  box-shadow: 0 15px 50px rgba(59, 130, 246, 0.25);
}

.profile-performance-content {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 28px;
}

.profile-performance-item {
  display: flex;
  flex-direction: column;
  gap: 12px;
  text-align: center;
  padding: 16px;
  border-radius: 12px;
  background: #0f1a2f;
  border: 1px solid #1f2a3e;
  transition: all 0.3s ease;
}

.profile-performance-item:hover {
  background: #1a2d42;
  border-color: #3b82f6;
  transform: translateY(-3px);
}

.profile-performance-label {
  font-size: 12px;
  font-weight: 700;
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.profile-performance-value {
  font-size: 24px;
  font-weight: 800;
  color: #ffffff;
}

/* Responsive - Sections */
@media (max-width: 768px) {
  .profile-stats-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .profile-learning-grid {
    grid-template-columns: 1fr;
  }

  .profile-performance-content {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .profile-section {
    padding: 24px;
  }
}

@media (max-width: 480px) {
  .profile-stats-grid {
    grid-template-columns: 1fr;
  }

  .profile-performance-content {
    grid-template-columns: 1fr;
  }

  .profile-section {
    padding: 16px;
    border-radius: 12px;
  }

  .profile-section-title {
    font-size: 18px;
    margin-bottom: 16px;
  }
}

/* ============================================
   LIGHT THEME - Profile Page
   ============================================ */

:root[data-theme='light'] .profile-container {
  background: linear-gradient(180deg, 
    #f8fafc 0%, 
    #f1f5f9 25%, 
    #e8f0fe 50%, 
    #f1f5f9 75%, 
    #f8fafc 100%);
}

:root[data-theme='light'] .profile-main-card {
  background: #ffffff;
  border-color: #e2e8f0;
}

:root[data-theme='light'] .profile-quick-stat {
  background: rgba(248, 250, 252, 0.8);
  border-color: rgba(226, 232, 240, 0.8);
  backdrop-filter: blur(10px);
}

:root[data-theme='light'] .profile-quick-stat::before {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.03) 0%, rgba(168, 85, 247, 0.03) 100%);
}

:root[data-theme='light'] .profile-quick-stat:hover {
  border-color: rgba(59, 130, 246, 0.4);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 8px 24px rgba(59, 130, 246, 0.12);
}

:root[data-theme='light'] .stat-label {
  color: rgba(15, 23, 40, 0.6) !important;
}

:root[data-theme='light'] .stat-number {
  color: #0f1728 !important;
}

:root[data-theme='light'] .profile-stat-card {
  background: rgba(255, 255, 255, 0.9);
  border-color: rgba(226, 232, 240, 0.8);
  backdrop-filter: blur(10px);
}

:root[data-theme='light'] .profile-stat-card::before {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.02) 0%, rgba(168, 85, 247, 0.02) 100%);
}

:root[data-theme='light'] .profile-stat-card:hover {
  border-color: rgba(59, 130, 246, 0.3);
  background: rgba(255, 255, 255, 1);
  box-shadow: 0 8px 24px rgba(59, 130, 246, 0.1);
}

:root[data-theme='light'] .profile-stat-label {
  color: rgba(15, 23, 40, 0.6);
}

:root[data-theme='light'] .profile-section {
  background: #ffffff;
  border-color: #e2e8f0;
}

:root[data-theme='light'] .profile-section-title {
  color: #0f1728;
}

:root[data-theme='light'] .detail-label {
  color: #64748b;
}

:root[data-theme='light'] .detail-value {
  color: #0f1728;
}

/* ============================================
   SKELETON LOADERS
   ============================================ */

@keyframes shimmer {
  0% { background-position: -1000px 0; }
  100% { background-position: 1000px 0; }
}

.skeleton-profile-stat-card {
  background: linear-gradient(
    90deg,
    #1a2d42 0%,
    #2d5a8f 50%,
    #1a2d42 100%
  );
  background-size: 1000px 100%;
  border: 2px solid #2d5a8f;
  border-radius: 16px;
  padding: 24px;
  min-height: 140px;
  animation: shimmer 2.5s ease-in-out infinite;
  position: relative;
  overflow: hidden;
}

.skeleton-profile-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 40px 20px;
}

.skeleton-profile-avatar {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: linear-gradient(
    90deg,
    #1a2d42 0%,
    #2d5a8f 50%,
    #1a2d42 100%
  );
  background-size: 200% 100%;
  margin: 0 auto 20px;
  animation: shimmer 2.5s ease-in-out infinite;
}

.skeleton-profile-name {
  width: 200px;
  height: 32px;
  background: linear-gradient(
    90deg,
    #1a2d42 0%,
    #2d5a8f 50%,
    #1a2d42 100%
  );
  background-size: 200% 100%;
  border-radius: 8px;
  margin: 0 auto 12px;
  animation: shimmer 2.5s ease-in-out infinite;
}

.skeleton-profile-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 16px;
  margin-bottom: 30px;
}

.skeleton-profile-item {
  height: 80px;
  background: linear-gradient(
    90deg,
    #1a2d42 0%,
    #2d5a8f 50%,
    #1a2d42 100%
  );
  background-size: 200% 100%;
  border-radius: 12px;
  animation: shimmer 2.5s ease-in-out infinite;
}

.skeleton-profile-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
}
